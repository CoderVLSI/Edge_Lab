# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edgelab

# ─── S3 / File Storage (MinIO for local dev) ─────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=edge-lab-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string

# ─── AI Providers ────────────────────────────────────────────────
# Set at least one. Providers without keys show "no key" in the UI.

# Anthropic Claude  https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI            https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini     https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# OpenRouter        https://openrouter.ai/keys  (access 300+ models)
OPENROUTER_API_KEY=sk-or-...

# Ollama (local)    https://ollama.ai  — no key needed, set base URL
OLLAMA_BASE_URL=http://localhost:11434

# ─── Git / Project filesystem ────────────────────────────────────
# Absolute path where project directories live on the API server
PROJECTS_DIR=E:/Edge-lab/projects

# ─── Service ports ───────────────────────────────────────────────
PORT=4000
SYNC_PORT=1234
LSP_PORT=1235

# ─── Frontend URLs (used by Next.js) ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SYNC_URL=ws://localhost:1234
NEXT_PUBLIC_LSP_URL=ws://localhost:1235

# ─── CORS ────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000

# ─── Expo mobile ─────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SYNC_URL=ws://localhost:1234
