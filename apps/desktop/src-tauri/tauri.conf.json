{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Edge Lab",
  "version": "0.0.1",
  "identifier": "app.edgelab.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm vite",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Edge Lab",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": false
    },
    "fs": {
      "all": true,
      "scope": ["$HOME/**", "$DOCUMENT/**", "$DESKTOP/**"]
    }
  }
}
