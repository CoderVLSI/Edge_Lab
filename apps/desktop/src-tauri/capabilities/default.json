{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Edge Lab desktop app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-spawn",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-open",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:scope-home-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-download-recursive",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
